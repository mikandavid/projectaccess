  "mentor_intro": {
    "eyebrow": {
      "de": "Mentor:in werden",
      "en": "Become a mentor"
    },
    "title": {
      "de": "1:1-Mentoring im internationalen Project\u00a0Access Programm.",
      "en": "1:1 mentoring in the international Project\u00a0Access programme."
    },
    "body": {
      "de": "Mentor:innen begleiten junge Menschen aus Österreich und Südtirol bei Essays, Interviews und Auswahlprozessen. Du brauchst keine perfekten Antworten – Erfahrung, ehrliches Feedback und ein bisschen Zeit reichen oft schon sehr weit.",
      "en": "Mentors support students from Austria and South Tyrol with essays, interviews and selection processes. You do not need perfect answers – experience, honest feedback and a little time already help a lot."
    }
  },
  "fit": {
    "eyebrow": {
      "de": "Voraussetzungen",
      "en": "Requirements"
    },
    "title": {
      "de": "Mentoring passt, wenn du",
      "en": "Mentoring fits if you"
    },
    "items": [
      {
        "de": "aus Österreich oder Südtirol kommst oder den Bildungskontext kennst",
        "en": "are from Austria or South Tyrol, or are familiar with the educational context"
      },
      {
        "de": "an einer internationalen Universität studierst oder studiert hast",
        "en": "are studying or have studied at an international university"
      },
      {
        "de": "konstruktives Feedback geben kannst und Zeit investieren möchtest",
        "en": "can give constructive feedback and want to invest time"
      },
      {
        "de": "dich für fairen Hochschulzugang einsetzen möchtest",
        "en": "care about fair access to university"
      }
    ]
  },
  "team_intro": {
    "eyebrow": {
      "de": "Im PA\u00a0Austria Team",
      "en": "In the PA\u00a0Austria team"
    },
    "title": {
      "de": "Im Team Verantwortung übernehmen.",
      "en": "Take on a role in the team."
    },
    "body": {
      "de": "Wir organisieren Bootcamps, Schulbesuche, Studienmessen, Social Media, Kommunikation, Tech und Partnerschaften. Dafür suchen wir Menschen, die mitdenken und Aufgaben übernehmen.",
      "en": "We organise bootcamps, school visits, study fairs, social media, communications, tech and partnerships. We are looking for people who think along and take ownership."
    }
  },
