  "partner_quote": {
    "eyebrow": { "de": "Partnerstimme", "en": "Partner quote" },
    "quote": {
      "de": "Sozioökonomischer Hintergrund ist eine zentrale Dimension von Vielfalt. Project Access sorgt dafür, dass Talent und Leidenschaft den Bildungsweg bestimmen — nicht die Herkunft.",
      "en": "Socioeconomic background is a central dimension of diversity. Project Access ensures that talent and passion shape the educational path — not background."
    },
    "attribution": "Dr. Patrick Guggenberger · Associate Partner, McKinsey"
  },
  "schools": {
    "eyebrow": { "de": "Schulpartnerschaften", "en": "School partnerships" },
    "title": {
      "de": "Kostenlose Programme für **Schulen**.",
      "en": "Free programmes for **schools**."
    },
    "body": {
      "de": "Viele Talente erfahren zu spät, was möglich ist. Project Access Austria bringt Studierende und Alumni internationaler Universitäten direkt an österreichische Schulen — kostenlos und auf die Schule zugeschnitten.",
      "en": "Many students learn too late what is possible. Project Access Austria brings students and alumni of international universities directly to Austrian schools — free of charge and tailored to each school."
    },
    "cta": {
      "url": {
        "de": "mailto:austria@projectaccess.org?subject=Schulpartnerschaft%20mit%20PA%20Austria",
        "en": "mailto:austria@projectaccess.org?subject=School%20partnership%20with%20PA%20Austria"
      },
