{% extends "base.html.j2" %}
{% block content %}
      <section class="page-hero page-hero-split section-shell">
        <div>
          <p class="eyebrow">{{ page.hero.eyebrow[lang] }}</p>
          <h1>{{ page.hero.title[lang] | mark }}</h1>
          <p class="lead">{{ page.hero.lead[lang] }}</p>
          <div class="hero-actions">
            <a class="button" href="{{ t(page.hero.primary_cta.url) }}">{{ page.hero.primary_cta.label[lang] }}</a>
            <a class="button button-secondary" href="{{ t(page.hero.secondary_cta.url) }}">{{ page.hero.secondary_cta.label[lang] }}</a>
          </div>
        </div>
        <img class="page-hero-image" src="{{ asset(page.hero.image.src) }}" alt="{{ page.hero.image.alt[lang] }}" />
      </section>

      <section class="section-shell two-column-section">
        <div>
          <p class="eyebrow">{{ page.mentoring.eyebrow[lang] }}</p>
          <h2>{{ page.mentoring.title[lang] }}</h2>
        </div>
        <div class="text-stack">
          <p>{{ page.mentoring.body[lang] }}</p>
        </div>
      </section>

      <section class="section-shell">
        <div class="section-heading">
          <p class="eyebrow">{{ page.fit.eyebrow[lang] }}</p>
          <h2>{{ page.fit.title[lang] }}</h2>
        </div>
        <ul class="feature-list">
          {%- for item in page.fit['items'] %}
          <li>{{ item[lang] }}</li>
          {%- endfor %}
        </ul>
      </section>

      <section class="section-shell image-text-card">
        <img src="{{ asset(page.team_card.image.src) }}" alt="{{ page.team_card.image.alt[lang] }}" />
        <div>
          <p class="eyebrow">{{ page.team_card.eyebrow[lang] }}</p>
          <h2>{{ page.team_card.title[lang] }}</h2>
          <p>{{ page.team_card.body[lang] }}</p>
          <div class="hero-actions">
            <a class="button" href="{{ page_href(page.team_card.primary_cta.page) }}">{{ page.team_card.primary_cta.label[lang] }}</a>
            <a class="button button-secondary" href="{{ t(page.team_card.secondary_cta.url) }}">{{ page.team_card.secondary_cta.label[lang] }}</a>
          </div>
        </div>
      </section>

      <section class="section-shell">
        <div class="section-heading">
          <p class="eyebrow">{{ page.areas.eyebrow[lang] }}</p>
          <h2>{{ page.areas.title[lang] }}</h2>
        </div>
        <div class="bento">
          {%- for tile in page.areas.tiles %}
          <article class="bento-tile {{ tile.classes }}">
            <div>
              <p class="eyebrow">{{ tile.eyebrow[lang] }}</p>
              <h3>{{ tile.title[lang] }}</h3>
              {%- if tile.get('body') %}
              <p>{{ tile.body[lang] }}</p>
              {%- endif %}
            </div>
          </article>
          {%- endfor %}
        </div>
      </section>

      <section class="section-shell cta-panel">
        <p class="eyebrow">{{ page.cta_panel.eyebrow[lang] }}</p>
        <h2>{{ page.cta_panel.title[lang] }}</h2>
        <div class="hero-actions">
          <a class="button" href="{{ t(page.cta_panel.primary_cta.url) }}">{{ page.cta_panel.primary_cta.label[lang] }}</a>
          <a class="button button-secondary" href="{{ t(page.cta_panel.secondary_cta.url) }}">{{ page.cta_panel.secondary_cta.label[lang] }}</a>
        </div>
      </section>
{% endblock %}
