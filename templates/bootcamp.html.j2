{% extends "base.html.j2" %}
{% block content %}
      <section class="page-hero page-hero-split section-shell">
        <div>
          <p class="eyebrow">{{ page.hero.eyebrow[lang] }}</p>
          <h1>{{ page.hero.title[lang] | mark }}</h1>
          <p class="lead">{{ page.hero.lead[lang] }}</p>
          <div class="hero-actions">
            <a class="button" href="{{ t(page.hero.primary_cta.url) }}">{{ page.hero.primary_cta.label[lang] }}</a>
            <a class="button button-secondary" href="{{ t(page.hero.secondary_cta.url) }}">{{ page.hero.secondary_cta.label[lang] }}</a>
          </div>
        </div>
        <img class="page-hero-image" src="{{ asset(page.hero.image.src) }}" alt="{{ page.hero.image.alt[lang] }}" />
      </section>

      <section class="section-shell compact-section">
        <dl class="details details-grid">
          {%- for d in page.details %}
          <div>
            <dt>{{ d.term[lang] }}</dt>
            <dd>{{ d.definition[lang] }}</dd>
          </div>
          {%- endfor %}
        </dl>
      </section>

      <section class="section-shell two-column-section">
        <div>
          <p class="eyebrow">{{ page.about.eyebrow[lang] }}</p>
          <h2>{{ page.about.title[lang] }}</h2>
        </div>
        <div class="text-stack">
          <p>{{ page.about.body[lang] }}</p>
        </div>
      </section>

      <section class="section-shell">
        <div class="section-heading">
          <p class="eyebrow">{{ page.topics.eyebrow[lang] }}</p>
          <h2>{{ page.topics.title[lang] }}</h2>
        </div>
        <ul class="feature-list">
          {%- for item in page.topics['items'] %}
          <li>{{ item[lang] }}</li>
          {%- endfor %}
        </ul>
      </section>

      <section class="section-shell image-band" aria-label="{{ page.image_band.aria[lang] }}">
        {%- for img in page.image_band.images %}
        <img src="{{ asset(img.src) }}" alt="{{ img.alt[lang] }}" />
        {%- endfor %}
      </section>

      <section class="section-shell two-column-section">
        <div>
          <p class="eyebrow">{{ page.audience.eyebrow[lang] }}</p>
          <h2>{{ page.audience.title[lang] }}</h2>
        </div>
        <div class="text-stack">
          <p>{{ page.audience.body[lang] }}</p>
        </div>
      </section>

      <section class="section-shell faq-section">
        <div class="section-heading">
          <p class="eyebrow">{{ page.faq.eyebrow[lang] }}</p>
          <h2>{{ page.faq.title[lang] }}</h2>
        </div>
        <div class="faq-grid">
          {%- for item in page.faq['items'] %}
          <article>
            <h3>{{ item.question[lang] }}</h3>
            <p>{{ item.answer[lang] }}</p>
          </article>
          {%- endfor %}
        </div>
      </section>
{% endblock %}
