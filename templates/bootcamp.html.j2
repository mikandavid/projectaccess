{% extends "base.html.j2" %}
{% block og_type %}event{% endblock %}
{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "EducationEvent",
  "@id": "{{ canonical_url }}#bootcamp-2026",
  "name": {{ ("Project\u00a0Access\u00a0Austria Bootcamp 2026")|tojson }},
  "description": {{ page.meta.description[lang]|tojson }},
  "url": "{{ canonical_url }}",
  "image": "{{ og_image_url }}",
  "inLanguage": ["de-AT", "en"],
  "startDate": "2026-07-23",
  "endDate": "2026-07-26",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "eventStatus": "https://schema.org/EventScheduled",
  "isAccessibleForFree": true,
  "educationalLevel": "Secondary and tertiary applicants",
  "teaches": [
    "University course choice",
    "Personal statement and admissions essays",
    "CV and recommendation letters",
    "Standardised admissions tests",
    "Mock interviews (e.g.\u00a0Cambridge style)",
    "Funding, scholarships and living costs abroad"
  ],
  "location": {
    "@type": "Place",
    "name": "Horn,\u00a0Niederösterreich",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Horn",
      "addressRegion": "Niederösterreich",
      "addressCountry": "AT"
    }
  },
  "organizer": {"@id": "{{ site.site_url }}/#organization"},
  "performer": {"@id": "{{ site.site_url }}/#organization"},
  "audience": {
    "@type": "EducationalAudience",
    "educationalRole": "Prospective applicants from Austria and South Tyrol"
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/SoldOut",
    "validFrom": "2025-09-01",
    "url": "{{ canonical_url }}",
    "category": "Free, including accommodation and meals"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "{{ canonical_url }}#faq",
  "mainEntity": [
    {%- for item in page.faq['items'] %}
    {
      "@type": "Question",
      "name": {{ item.question[lang]|tojson }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ item.answer[lang]|tojson }}
      }
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>
{% endblock %}
{% block content %}
      <section class="page-hero page-hero-split section-shell">
        <div>
          <p class="eyebrow">{{ page.hero.eyebrow[lang] }}</p>
          <h1>{{ page.hero.title[lang] | mark }}</h1>
          <p class="lead">{{ page.hero.lead[lang] }}</p>
          {%- if page.hero.get('notice') %}
          <p class="hero-notice" role="status">{{ page.hero.notice[lang] }}</p>
          {%- endif %}
          <div class="hero-actions">
            <a class="button" href="{{ t(page.hero.primary_cta.url) }}">{{ page.hero.primary_cta.label[lang] }}</a>
            <a class="button button-secondary" href="{{ t(page.hero.secondary_cta.url) }}">{{ page.hero.secondary_cta.label[lang] }}</a>
          </div>
        </div>
        <img class="page-hero-image" src="{{ asset(page.hero.image.src) }}" alt="{{ page.hero.image.alt[lang] }}" fetchpriority="high" decoding="async" />
      </section>

      <section class="section-shell compact-section">
        <dl class="details details-grid">
          {%- for d in page.details %}
          <div>
            <dt>{{ d.term[lang] }}</dt>
            <dd>{{ d.definition[lang] }}</dd>
          </div>
          {%- endfor %}
        </dl>
      </section>

      <section class="section-shell two-column-section">
        <div>
          <p class="eyebrow">{{ page.about.eyebrow[lang] }}</p>
          <h2>{{ page.about.title[lang] }}</h2>
        </div>
        <div class="text-stack">
          <p>{{ page.about.body[lang] }}</p>
        </div>
      </section>

      <section class="section-shell topics-section">
        <div class="section-heading">
          <p class="eyebrow">{{ page.topics.eyebrow[lang] }}</p>
          <h2>{{ page.topics.title[lang] }}</h2>
          {%- if page.topics.get('body') %}
          <p>{{ page.topics.body[lang] }}</p>
          {%- endif %}
        </div>
        <ul class="feature-list feature-list-prominent">
          {%- for item in page.topics['items'] %}
          <li>{{ item[lang] }}</li>
          {%- endfor %}
        </ul>
      </section>

      <section class="section-shell image-band" aria-label="{{ page.image_band.aria[lang] }}">
        {%- for img in page.image_band.images %}
        <img src="{{ asset(img.src) }}" alt="{{ img.alt[lang] }}" loading="lazy" decoding="async" />
        {%- endfor %}
      </section>

      <section class="section-shell two-column-section">
        <div>
          <p class="eyebrow">{{ page.audience.eyebrow[lang] }}</p>
          <h2>{{ page.audience.title[lang] }}</h2>
        </div>
        <div class="text-stack">
          <p>{{ page.audience.body[lang] }}</p>
        </div>
      </section>

      <section class="section-shell video-section" aria-labelledby="bootcamp-video-heading">
        <div class="section-heading">
          <p class="eyebrow">{{ page.video.eyebrow[lang] }}</p>
          <h2 id="bootcamp-video-heading">{{ page.video.title[lang] }}</h2>
          <p>{{ page.video.body[lang] }}</p>
        </div>
        <div class="video-embed">
          <iframe
            src="{{ page.video.src }}"
            title="{{ page.video.iframe_title[lang] }}"
            referrerpolicy="strict-origin-when-cross-origin"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </section>

      <section class="section-shell faq-section">
        <div class="section-heading">
          <p class="eyebrow">{{ page.faq.eyebrow[lang] }}</p>
          <h2>{{ page.faq.title[lang] }}</h2>
        </div>
        <div class="faq-grid">
          {%- for item in page.faq['items'] %}
          <article>
            <h3>{{ item.question[lang] }}</h3>
            <p>{{ item.answer[lang] }}</p>
          </article>
          {%- endfor %}
        </div>
      </section>
{% endblock %}
