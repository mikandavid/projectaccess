{% extends "base.html.j2" %}
{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "EducationEvent",
  "@id": "{{ site.site_url }}/{{ 'en/' if lang == 'en' else '' }}bootcamp.html#bootcamp-2026",
  "name": {{ ("Project\u00a0Access\u00a0Austria Bootcamp 2026")|tojson }},
  "description": {{ ("Vier Tage kostenloses Bewerbungstraining vom 23.-26.\u00a0Juli\u00a02026 in Horn,\u00a0Niederösterreich, für Schüler:innen und Studierende aus Österreich und Südtirol, die sich an internationalen Top-Universitäten bewerben." if lang == "de" else "Four days of free application training from 23-26\u00a0July\u00a02026 in Horn,\u00a0Lower Austria, for students from Austria and South Tyrol applying to top international universities.")|tojson }},
  "url": "{{ site.site_url }}/{{ 'en/' if lang == 'en' else '' }}bootcamp.html",
  "startDate": "2026-07-23",
  "endDate": "2026-07-26",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "eventStatus": "https://schema.org/EventScheduled",
  "isAccessibleForFree": true,
  "location": {
    "@type": "Place",
    "name": "Horn,\u00a0Niederösterreich",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Horn",
      "addressRegion": "Niederösterreich",
      "addressCountry": "AT"
    }
  },
  "organizer": {"@id": "{{ site.site_url }}/#organization"},
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock",
    "url": "https://airtable.com/appSrxV1MH9LEChsv/shrIVlh0hcQlHqStE"
  }
}
</script>
{% endblock %}
{% block content %}
      <section class="page-hero page-hero-split section-shell">
        <div>
          <p class="eyebrow">{{ page.hero.eyebrow[lang] }}</p>
          <h1>{{ page.hero.title[lang] | mark }}</h1>
          <p class="lead">{{ page.hero.lead[lang] }}</p>
          <div class="hero-actions">
            <a class="button" href="{{ t(page.hero.primary_cta.url) }}">{{ page.hero.primary_cta.label[lang] }}</a>
            <a class="button button-secondary" href="{{ t(page.hero.secondary_cta.url) }}">{{ page.hero.secondary_cta.label[lang] }}</a>
          </div>
        </div>
        <img class="page-hero-image" src="{{ asset(page.hero.image.src) }}" alt="{{ page.hero.image.alt[lang] }}" fetchpriority="high" decoding="async" />
      </section>

      <section class="section-shell next-event-card">
        <img src="{{ asset(page.next_event.image.src) }}" alt="{{ page.next_event.image.alt[lang] }}" loading="lazy" decoding="async" />
        <div class="next-event-copy">
          <p class="eyebrow next-event-eyebrow">
            <span>{{ page.next_event.eyebrow[lang] }}</span>
            <span class="next-event-status">
              <span class="next-event-pulse" aria-hidden="true"></span>
              {{ page.next_event.status_label[lang] }}
            </span>
          </p>
          <h2>{{ page.next_event.title }}</h2>
          <p>{{ page.next_event.summary[lang] }}</p>
          <dl class="details">
            {%- for d in page.next_event.details %}
            <div>
              <dt>{{ d.term[lang] }}</dt>
              <dd>{{ d.definition[lang] }}</dd>
            </div>
            {%- endfor %}
          </dl>
          <div class="hero-actions">
            <a class="button" href="{{ t(page.next_event.primary_cta.url) }}">{{ page.next_event.primary_cta.label[lang] }}</a>
            <a class="button button-secondary" href="{{ page_href(page.next_event.secondary_cta.page) }}">{{ page.next_event.secondary_cta.label[lang] }}</a>
          </div>
        </div>
      </section>

      <section class="section-shell">
        <div class="section-heading">
          <p class="eyebrow">{{ page.programmes.eyebrow[lang] }}</p>
          <h2>{{ page.programmes.title[lang] }}</h2>
          {%- if page.programmes.get('lead') %}
          <p>{{ page.programmes.lead[lang] }}</p>
          {%- endif %}
        </div>
        <div class="bento support-bento">
          {%- for tile in page.programmes.tiles %}
          <article class="bento-tile {{ tile.classes }}">
            <div>
              <p class="eyebrow"{% if tile.get('eyebrow_inverted') %} style="color: rgba(255, 255, 255, 0.72);"{% endif %}>{{ tile.eyebrow[lang] }}</p>
              <h3>{{ tile.title[lang] }}</h3>
              {%- if tile.get('body') %}
              <p>{{ tile.body[lang] }}</p>
              {%- endif %}
            </div>
          </article>
          {%- endfor %}
        </div>
      </section>

      <section class="section-shell stay-updated">
        <div class="stay-updated-copy">
          <p class="eyebrow">{{ page.stay_updated.eyebrow[lang] }}</p>
          <h2>{{ page.stay_updated.title[lang] }}</h2>
          <p>{{ page.stay_updated.body[lang] }}</p>
        </div>
        <ul class="stay-updated-channels">
          {%- for channel in page.stay_updated.channels %}
          <li>
            <a href="{{ channel.url }}"{% if channel.url.startswith('http') %} target="_blank" rel="noopener"{% endif %}>
              <span class="stay-updated-icon" aria-hidden="true">
                {%- if channel.icon == 'instagram' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                </svg>
                {%- elif channel.icon == 'newsletter' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 2 11 13" />
                  <path d="M22 2 15 22l-4-9-9-4 20-7Z" />
                </svg>
                {%- elif channel.icon == 'email' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="m3 7 9 6 9-6" />
                </svg>
                {%- endif %}
              </span>
              <span class="stay-updated-text">
                <span class="stay-updated-sub">{{ channel.sublabel[lang] }}</span>
                <span class="stay-updated-label">{{ channel.label }}</span>
              </span>
            </a>
          </li>
          {%- endfor %}
        </ul>
      </section>

      <section class="section-shell">
        <div class="section-heading">
          <p class="eyebrow">{{ page.archive.eyebrow[lang] }}</p>
          <h2>{{ page.archive.title[lang] }}</h2>
        </div>
        <div class="archive-grid archive-grid-rich">
          {%- for item in page.archive['items'] %}
          <article>
            {%- if item.get('image') %}
            <img src="{{ asset(item.image) }}" alt="{{ item.image_alt[lang] }}" loading="lazy" decoding="async" />
            {%- endif %}
            <div class="archive-meta">
              <span class="archive-tag">{{ item.tag[lang] }}</span>
              {%- if item.get('date') %}
              <span class="archive-date">{{ item.date[lang] }}</span>
              {%- endif %}
            </div>
            <h3>{{ item.title }}</h3>
            <p>{{ item.body[lang] }}</p>
          </article>
          {%- endfor %}
        </div>
      </section>

      {% include "_partials/press.html.j2" %}
{% endblock %}
