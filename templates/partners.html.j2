{% extends "base.html.j2" %}
{% block content %}
      <section class="page-hero page-hero-split section-shell">
        <div>
          <p class="eyebrow">{{ page.hero.eyebrow[lang] }}</p>
          <h1>{{ page.hero.title[lang] | mark }}</h1>
          <p class="lead">{{ page.hero.lead[lang] }}</p>
          <div class="hero-actions">
            <a class="button" href="{{ t(page.hero.primary_cta.url) }}">{{ page.hero.primary_cta.label[lang] }}</a>
            <a class="button button-secondary" href="#{{ anchor(page.hero.secondary_cta.anchor_key) }}">{{ page.hero.secondary_cta.label[lang] }}</a>
          </div>
        </div>
        <img class="page-hero-image" src="{{ asset(page.hero.image.src) }}" alt="{{ page.hero.image.alt[lang] }}" fetchpriority="high" decoding="async" />
      </section>

      <section class="section-shell two-column-section">
        <div>
          <p class="eyebrow">{{ page.intro.eyebrow[lang] }}</p>
          <h2>{{ page.intro.title[lang] }}</h2>
        </div>
        <div class="text-stack">
          <p>{{ page.intro.body[lang] }}</p>
        </div>
      </section>

      <section class="section-shell impact-stats" aria-label="{{ page.impact.title[lang] }}">
        <div class="impact-stats-heading">
          <p class="eyebrow">{{ page.impact.eyebrow[lang] }}</p>
          <h2>{{ page.impact.title[lang] }}</h2>
        </div>
        <div class="impact-stats-grid">
          {%- for item in page.impact['items'] %}
          <article>
            <strong>{{ t(item.value) }}</strong>
            <span>{{ item.label[lang] }}</span>
          </article>
          {%- endfor %}
        </div>
        {%- if page.impact.get('note') %}
        <p class="impact-stats-note">{{ page.impact.note[lang] }}</p>
        {%- endif %}
      </section>

      <section class="section-shell">
        <div class="section-heading">
          <p class="eyebrow">{{ page.support_forms.eyebrow[lang] }}</p>
          <h2>{{ page.support_forms.title[lang] }}</h2>
          {%- if page.support_forms.get('lead') %}
          <p>{{ page.support_forms.lead[lang] }}</p>
          {%- endif %}
        </div>
        <div class="bento support-bento">
          {%- for tile in page.support_forms.tiles %}
          <article class="bento-tile {{ tile.classes }}">
            <div>
              <p class="eyebrow"{% if tile.get('eyebrow_inverted') %} style="color: rgba(255, 255, 255, 0.72);"{% endif %}>{{ tile.eyebrow[lang] }}</p>
              <h3>{{ tile.title[lang] }}</h3>
              {%- if tile.get('body') %}
              <p>{{ tile.body[lang] }}</p>
              {%- endif %}
            </div>
          </article>
          {%- endfor %}
        </div>
      </section>

      <section class="section-shell partner-logos-section">
        <div class="partner-logos-heading">
          <p class="eyebrow">{{ page.partner_examples.eyebrow[lang] }}</p>
          <h2>{{ page.partner_examples.title[lang] }}</h2>
          {%- if page.partner_examples.get('body') %}
          <p>{{ page.partner_examples.body[lang] }}</p>
          {%- endif %}
        </div>
        <ul class="partner-logo-strip">
          {%- for item in page.partner_examples['items'] %}
          {%- set item_name = item if item is string else item.name %}
          <li class="partner-logo-item">
            {%- if item is mapping and item.get('logo') %}
            <img src="{{ asset(item.logo) }}" alt="{{ item_name }}" loading="lazy" decoding="async" />
            {%- else %}
            <span class="partner-logo-text">{{ item_name }}</span>
            {%- endif %}
          </li>
          {%- endfor %}
        </ul>
      </section>

      <section class="section-shell partner-quote-section">
        <p class="eyebrow">{{ page.partner_quote.eyebrow[lang] }}</p>
        <figure class="partner-quote-card">
          <blockquote>
            <p>{{ page.partner_quote.quote[lang] }}</p>
          </blockquote>
          <figcaption>
            <strong>{{ page.partner_quote.attribution_name }}</strong>
            <span>{{ page.partner_quote.attribution_role[lang] }}</span>
          </figcaption>
        </figure>
      </section>

      <span class="divider-dots" aria-hidden="true"></span>

      <section class="section-shell schools-chapter" id="{{ anchor('schools') }}">
        <div class="schools-chapter-copy">
          <p class="eyebrow">{{ page.schools.eyebrow[lang] }}</p>
          <h2>{{ page.schools.title[lang] | mark }}</h2>
          <p>{{ page.schools.body[lang] }}</p>
          {%- if page.schools.get('facts') %}
          <ul class="schools-chapter-facts">
            {%- for fact in page.schools.facts %}
            <li>{{ fact[lang] }}</li>
            {%- endfor %}
          </ul>
          {%- endif %}
          <div class="hero-actions">
            <a class="button" href="{{ t(page.schools.cta.url) }}">{{ page.schools.cta.label[lang] }}</a>
          </div>
        </div>
        <img class="schools-chapter-image" src="{{ asset(page.schools.image.src) }}" alt="{{ page.schools.image.alt[lang] }}" loading="lazy" decoding="async" />
      </section>

      <section class="section-shell cta-panel">
        <p class="eyebrow">{{ page.cta_panel.eyebrow[lang] }}</p>
        <h2>{{ page.cta_panel.title[lang] }}</h2>
        <p>{{ page.cta_panel.body[lang] }}</p>
        <div class="hero-actions">
          <a class="button" href="{{ t(page.cta_panel.primary_cta.url) }}">{{ page.cta_panel.primary_cta.label[lang] }}</a>
          <a class="button button-secondary" href="{{ t(page.cta_panel.secondary_cta.url) }}">{{ page.cta_panel.secondary_cta.label[lang] }}</a>
        </div>
      </section>
{% endblock %}
