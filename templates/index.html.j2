{% extends "base.html.j2" %}
{% set main_id = "top" %}
{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "@id": "{{ canonical_url }}#programme",
  "name": {{ page.programme.title[lang]|tojson }},
  "url": "{{ canonical_url }}#{{ anchor('programme') }}",
  "provider": {"@id": "{{ site.site_url }}/#organization"},
  "itemListElement": [
    {%- for item in page.programme['items'] %}
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": {{ item.title[lang]|tojson }},
        "description": {{ item.body[lang]|tojson }},
        "provider": {"@id": "{{ site.site_url }}/#organization"},
        "areaServed": [{"@type": "Country", "name": "AT"}, {"@type": "Country", "name": "IT-32-BZ"}]
      },
      "price": "0",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>
{% endblock %}
{% block content %}
      <section class="hero section-shell">
        <div class="hero-copy">
          <a class="save-the-date" href="{{ page_href('bootcamp') }}">
            <div class="save-the-date-date">
              <span class="save-the-date-kicker">{{ page.hero.banner.kicker[lang] }}</span>
              <span class="save-the-date-day">{{ page.hero.banner.date.day[lang] }}</span>
              <span class="save-the-date-month">{{ page.hero.banner.date.month[lang] }}</span>
            </div>
            <span class="save-the-date-perf" aria-hidden="true"></span>
            <div class="save-the-date-body">
              <p class="save-the-date-event">{{ page.hero.banner.event[lang] }}</p>
              <p class="save-the-date-location">{{ page.hero.banner.location[lang] }}</p>
              <span class="save-the-date-link">{{ page.hero.banner.link_text[lang] }}</span>
            </div>
            <span class="save-the-date-status">
              <span class="save-the-date-pulse" aria-hidden="true"></span>
              <span>{{ page.hero.banner.status[lang] }}</span>
            </span>
          </a>
          <p class="eyebrow">{{ page.hero.eyebrow[lang] }}</p>
          <h1>{{ page.hero.title[lang] | mark }}</h1>
          <p class="lead">{{ page.hero.lead[lang] }}</p>
          <div class="hero-actions">
            <a class="button" href="{{ t(page.hero.primary_cta.url) }}">{{ page.hero.primary_cta.label[lang] }}</a>
            <a class="button button-secondary" href="{{ t(page.hero.secondary_cta.url) if page.hero.secondary_cta.get('url') else page_href(page.hero.secondary_cta.page) }}">{{ page.hero.secondary_cta.label[lang] }}</a>
          </div>
        </div>

        <div class="hero-media" aria-label="{{ page.hero.image.caption[lang] }}">
          <img src="{{ asset(page.hero.image.src) }}" alt="{{ page.hero.image.alt[lang] }}" fetchpriority="high" decoding="async" />
        </div>
      </section>

      <section class="university-carousel section-shell" aria-label="{{ page.universities.aria[lang] }}">
        <p class="university-carousel-label">{{ page.universities.label[lang] }}</p>
        <div class="university-carousel-viewport">
          <div class="university-carousel-track">
            {%- for university in page.universities['items'] %}
            <span class="university-logo">
              <img src="{{ university.logo if university.logo.startswith('http') else asset(university.logo) }}" alt="{{ university.name }}" loading="lazy" />
            </span>
            {%- endfor %}
            {%- for university in page.universities['items'] %}
            <span class="university-logo" aria-hidden="true">
              <img src="{{ university.logo if university.logo.startswith('http') else asset(university.logo) }}" alt="" loading="lazy" />
            </span>
            {%- endfor %}
          </div>
        </div>
      </section>

      <section class="intro section-shell">
        <div>
          <p class="eyebrow">{{ page.intro.eyebrow[lang] }}</p>
          <h2>{{ page.intro.title[lang] | mark }}</h2>
        </div>
        <div class="text-stack">
          <p>{{ page.intro.body[lang] }}</p>
          {%- if page.intro.get('cta') %}
          <a class="inline-link" href="{{ page.intro.cta.url }}">{{ page.intro.cta.label[lang] }}</a>
          {%- endif %}
        </div>
      </section>

      <section class="section-shell" id="{{ anchor('programme') }}">
        <div class="section-heading">
          <p class="eyebrow">{{ page.programme.eyebrow[lang] }}</p>
          <h2>{{ page.programme.title[lang] | mark }}</h2>
        </div>
        <ol class="program-list">
          {%- for item in page.programme['items'] %}
          <li>
            <h3>{{ item.title[lang] }}</h3>
            <p>{{ item.body[lang] }}</p>
          </li>
          {%- endfor %}
        </ol>
      </section>

      <section class="bootcamp section-shell" id="{{ anchor('bootcamp') }}">
        <div class="image-collage">
          <img class="image-large" src="{{ asset(page.bootcamp.image_large.src) }}" alt="{{ page.bootcamp.image_large.alt[lang] }}" loading="lazy" decoding="async" />
          <img class="image-small" src="{{ asset(page.bootcamp.image_small.src) }}" alt="{{ page.bootcamp.image_small.alt[lang] }}" loading="lazy" decoding="async" />
        </div>
        <div class="bootcamp-copy">
          <p class="eyebrow">{{ page.bootcamp.eyebrow[lang] }}</p>
          <h2>{{ page.bootcamp.title[lang] | mark }}</h2>
          <p>{{ page.bootcamp.body[lang] }}</p>
          <dl class="details">
            {%- for d in page.bootcamp.details %}
            <div>
              <dt>{{ d.term[lang] }}</dt>
              <dd>{{ d.definition[lang] }}</dd>
            </div>
            {%- endfor %}
          </dl>
          <a class="button" href="{{ page_href(page.bootcamp.cta.page) }}">{{ page.bootcamp.cta.label[lang] }}</a>
        </div>
      </section>

      <span class="divider-dots" aria-hidden="true"></span>

      <section class="section-shell" id="{{ anchor('engagement') }}">
        <div class="section-heading">
          <p class="eyebrow">{{ page.engagement.eyebrow[lang] }}</p>
          <h2>{{ page.engagement.title[lang] | mark }}</h2>
        </div>
        <div class="bento">
          {%- for tile in page.engagement.tiles %}
          <article class="bento-tile {{ tile.classes }}">
            <div>
              <p class="eyebrow"{% if tile.get('eyebrow_inverted') %} style="color: rgba(255, 255, 255, 0.72);"{% endif %}>{{ tile.eyebrow[lang] }}</p>
              <h3>{{ tile.title[lang] }}</h3>
              {%- if tile.get('body') %}
              <p>{{ tile.body[lang] }}</p>
              {%- endif %}
            </div>
            <a class="tile-link" href="{{ page_href(tile.link.page, anchor_key=tile.link.get('anchor_key')) }}">{{ tile.link.label[lang] }}</a>
          </article>
          {%- endfor %}
        </div>
      </section>

      <section class="section-shell partners">
        <div class="section-heading">
          <p class="eyebrow">{{ page.partner_quote.eyebrow[lang] }}</p>
          <h2>{{ page.partner_quote.title[lang] }}</h2>
        </div>
        <blockquote class="quote">
          <p>{{ page.partner_quote.quote[lang] }}</p>
          <footer>{{ page.partner_quote.attribution }}</footer>
        </blockquote>
        <p class="partners-cta">
          {{ page.partner_quote.cta_text[lang] }}
          <a href="{{ page_href(page.partner_quote.cta_link.page) }}">{{ page.partner_quote.cta_link.label[lang] }}</a>
        </p>
      </section>

      <section class="team-section section-shell" id="{{ anchor('team') }}">
        <div class="section-heading">
          <p class="eyebrow">{{ page.team_preview.eyebrow[lang] }}</p>
          <h2>{{ page.team_preview.title[lang] }}</h2>
        </div>
        <div class="team-grid">
          {%- for member in team_preview_members %}
          <article class="team-card">
            <img src="{{ asset(member.image) }}" alt="{{ member.name }} – {{ member.role[lang] }}" loading="lazy" decoding="async" />
            <div class="team-card-body">
              <div class="team-card-header">
                <h3>{{ member.name }}</h3>
                {%- if member.get('linkedin') %}
                <a class="team-card-linkedin" href="{{ member.linkedin }}" aria-label="{{ ('LinkedIn-Profil von ' if lang == 'de' else 'LinkedIn profile of ') ~ member.name }}" target="_blank" rel="noopener noreferrer">
                  <span class="team-card-linkedin-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                      <path d="M6.94 8.5A1.56 1.56 0 1 1 6.94 5.38a1.56 1.56 0 0 1 0 3.12ZM5.56 18.5h2.76V9.88H5.56V18.5Zm4.5 0h2.76v-4.8c0-1.26.24-2.48 1.8-2.48 1.54 0 1.56 1.44 1.56 2.56v4.72H19v-5.28c0-2.6-.56-4.6-3.6-4.6-1.46 0-2.44.8-2.84 1.56h-.04V9.88h-2.46V18.5Z" />
                    </svg>
                  </span>
                </a>
                {%- endif %}
              </div>
              <p>{{ member.role[lang] }}</p>
            </div>
          </article>
          {%- endfor %}
          <a class="team-card team-cta-card" href="{{ page_href(page.team_preview.cta.page) }}" aria-label="{{ page.team_preview.cta.aria[lang] }}">
            <h3>{{ page.team_preview.cta.label_h3[lang] }}</h3>
            {%- if page.team_preview.cta.label_body[lang] %}
            <p>{{ page.team_preview.cta.label_body[lang] }}</p>
            {%- endif %}
            <strong>{{ page.team_preview.cta.label_link[lang] }}</strong>
          </a>
        </div>
      </section>

      <section class="stats section-shell" aria-label="{{ page.stats.aria[lang] }}">
        {%- for stat in page.stats['items'] %}
        <article>
          <strong>{{ stat.value }}</strong>
          <span>{{ stat.label[lang] }}</span>
        </article>
        {%- endfor %}
        {%- if page.stats.get('note') %}
        <p class="stats-note">{{ page.stats.note[lang] }}</p>
        {%- endif %}
      </section>

      <section class="news-contact section-shell" id="{{ anchor('contact') }}">
        <div class="event-card">
          <p class="eyebrow news-eyebrow">
            <svg class="news-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 19a2 2 0 0 1-2-2V6a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v11a2 2 0 0 0 2 2H5Z" />
              <path d="M17 9h3v8a2 2 0 0 1-2 2" />
              <path d="M7 9h6" />
              <path d="M7 13h6" />
              <path d="M7 17h3" />
            </svg>
            <span>{{ page.news_contact.news.eyebrow[lang] }}</span>
          </p>
          <h2>{{ page.news_contact.news.title[lang] }}</h2>
          <p>{{ page.news_contact.news.body[lang] }}</p>
          <a class="inline-link" href="{{ page_href(page.news_contact.news.cta.page) }}">{{ page.news_contact.news.cta.label[lang] }}</a>
        </div>
        <div class="contact-card">
          <p class="eyebrow">{{ page.news_contact.contact.eyebrow[lang] }}</p>
          <h2>{{ page.news_contact.contact.title[lang] }}</h2>
          <a href="mailto:{{ site.footer.email }}">
            <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="m3 7 9 6 9-6" />
            </svg>
            <span>{{ site.footer.email }}</span>
          </a>
          <a href="{{ site.footer.instagram.url }}">
            <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
            </svg>
            <span>@projectaccess.at</span>
          </a>
        </div>
      </section>

      {% include "_partials/press.html.j2" %}
{% endblock %}
