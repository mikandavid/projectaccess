{%- set main_id = main_id|default(none) -%}
<!doctype html>
<html lang="{{ lang }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="{{ page.meta.description[lang] }}" />
    <title>{{ page.meta.title[lang] }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{{ asset('styles.css') }}" />
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
    <link rel="alternate" hreflang="de" href="{{ alt_lang_href if lang == 'en' else self_href }}" />
    <link rel="alternate" hreflang="en" href="{{ alt_lang_href if lang == 'de' else self_href }}" />
  </head>
  <body>
    {% include "_partials/header.html.j2" %}
    <main{% if main_id %} id="{{ main_id }}"{% endif %}>
      {% block content %}{% endblock %}
    </main>
    {% include "_partials/footer.html.j2" %}
    <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>
    <script type="text/javascript">
      window.addEventListener("load", function () {
        if (!window.Calendly) {
          return;
        }

        window.Calendly.initBadgeWidget({
          url: {{ site.calendly_badge.url|tojson }},
          text: {{ site.calendly_badge.text[lang]|tojson }},
          color: {{ site.calendly_badge.color|tojson }},
          textColor: {{ site.calendly_badge.text_color|tojson }},
          branding: {{ site.calendly_badge.branding|tojson }}
        });
      });
    </script>
  </body>
</html>
