    <header class="site-header">
      <a class="brand" href="{{ page_href('index') }}#top" aria-label="{{ site.brand_aria[lang] }}">
        <img class="brand-logo" src="{{ site.brand_logo_src if site.brand_logo_src.startswith('http') else asset(site.brand_logo_src) }}" alt="" aria-hidden="true" />
      </a>
      <div class="header-actions">
        <a class="lang-switch" href="{{ alt_lang_href }}" aria-label="{{ site.language_switch.label[lang] }}">
          <span class="lang-switch-link{% if lang == 'de' %} is-active{% endif %}" {% if lang == 'de' %}aria-current="true"{% endif %}>{{ site.language_switch.de_label }}</span>
          <span class="lang-switch-sep" aria-hidden="true">·</span>
          <span class="lang-switch-link{% if lang == 'en' %} is-active{% endif %}" {% if lang == 'en' %}aria-current="true"{% endif %}>{{ site.language_switch.en_label }}</span>
        </a>
        {% if page.header_cta %}
        {% set cta_short = page.header_cta.short_label[lang] if page.header_cta.get('short_label') and page.header_cta.short_label.get(lang) else none %}
        <a class="button button-small header-cta{% if cta_short %} header-cta-shortenable{% endif %}" href="{{ t(page.header_cta.url) }}">
          <span class="header-cta-label header-cta-label-full">{{ page.header_cta.label[lang] }}</span>
          {% if cta_short %}
          <span class="header-cta-label header-cta-label-short">{{ cta_short }}</span>
          {% endif %}
        </a>
        {% endif %}
      </div>
      <input
        id="site-nav-toggle"
        class="nav-toggle-input"
        type="checkbox"
        aria-label="{{ site.menu_toggle.open_label[lang] }}"
      />
      <label for="site-nav-toggle" class="nav-toggle" aria-hidden="true">
        <span class="nav-toggle-bars" aria-hidden="true"></span>
      </label>
      <div class="nav-shell-panel">
        <nav class="nav" aria-label="{{ site.nav_aria[lang] }}">
          {%- for item in site.nav %}
          <a href="{{ page_href(item.page, anchor_key=item.get('anchor_key')) }}"{% if item.page == page_key and not item.get('anchor_key') %} class="is-active" aria-current="page"{% endif %}>{{ item.label[lang] }}</a>
          {%- endfor %}
        </nav>
        <a class="mobile-lang-link" href="{{ alt_lang_href }}">{{ site.language_switch.mobile_label[lang] }}</a>
      </div>
    </header>
