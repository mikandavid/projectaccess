      <section class="press section-shell">
        <p class="eyebrow press-eyebrow">
          <svg class="press-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 19a2 2 0 0 1-2-2V6a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v11a2 2 0 0 0 2 2H5Z" />
            <path d="M17 9h3v8a2 2 0 0 1-2 2" />
            <path d="M7 9h6" />
            <path d="M7 13h6" />
            <path d="M7 17h3" />
          </svg>
          <span>{{ site.press.eyebrow[lang] }}</span>
        </p>
        <ul class="press-list">
          {%- for item in site.press['items'] %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
          {%- endfor %}
        </ul>
      </section>
